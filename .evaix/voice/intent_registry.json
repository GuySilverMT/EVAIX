      "id": "system.wifi.on",
      "description": "Turn on Wi-Fi connection",
      "triggers": ["turn on wifi", "enable wifi", "start wifi"],
      "action": {
        "type": "shell",
        "command": ".evaix/voice/scripts/system/wifi.sh on"
      }
    },
    {
      "id": "system.wifi.off",
      "description": "Turn off Wi-Fi connection",
      "triggers": ["turn off wifi", "disable wifi", "stop wifi"],
      "action": {
        "type": "shell",
        "command": ".evaix/voice/scripts/system/wifi.sh off"
      }
    },
    {
      "id": "system.wifi.toggle",
      "description": "Toggle Wi-Fi connection",
      "triggers": ["toggle wifi", "switch wifi"],
      "action": {
        "type": "shell",
        "command": ".evaix/voice/scripts/system/wifi.sh toggle"
      }
