    "@mui/x-date-pickers": "^7.29.4",
    "@radix-ui/react-slot": "^1.2.4",
    "@repo/common": "workspace:*",
    "@repo/nebula": "workspace:*",
    "@tanstack/react-query": "^4.36.1",
    "@tiptap/core": "^3.26.1",
