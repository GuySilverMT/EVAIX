{
  "name": "ui",
  "private": true,
  "version": "0.0.0",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "node scripts/generate-theme.mjs && concurrently \"vite\" \"chokidar 'src/theme/theme.json' -c 'node scripts/generate-theme.mjs'\"",
    "desktop": "concurrently \"vite\" \"wait-on tcp:5173 tcp:4000 && VK_ICD_FILENAMES=/usr/share/vulkan/icd.d/nvidia_icd.x86_64.json electron . --no-sandbox --ignore-gpu-blocklist --enable-gpu-rasterization --enable-unsafe-swiftshader --disable-gpu-process-crash-limit\"",
    "build": "node scripts/generate-theme.mjs && vite build",
    "lint": "eslint -c eslint.config.mjs .",
    "lint:fix": "eslint -c eslint.config.mjs . --fix",
    "preview": "vite preview",
    "tailwind:init": "tailwindcss init -p",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@aldabil/react-scheduler": "^3.1.2",
