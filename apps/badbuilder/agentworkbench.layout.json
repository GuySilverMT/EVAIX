{
"meta": {
"tool": "layout-designer-v5",
"name": "CooperativeLayout"
},
"vars": {
"colors": {
"background": "#0e0e0f",
"surface": "#18181a",
"surface2": "#222226",
"primary": "#7c6bff",
"text": "#e8e8ec",
"text2": "#c8c8d0",
"border": "#333338"
},
"fonts": {
"main": "'Inter', sans-serif"
},
"sizes": {
"body": "12"
},
"icons": {
"standard": {
"size": 20,
"stroke": 2,
"color": "var(--primary)"
}
}
},
"state": {
"_uid": 1,
"globalAiNotes": "Layout structure containing GlobalContextBar, Main stage, and overlays for ThemeSidebar, ContextMenu, and VoiceKeyboard.",
"blocks": [
{
"id": "root-container",
"role": "container",
"name": "App Shell",
"parentId": null,
"x": 0,
"y": 0,
"w": 1920,
"h": 1080,
"fillParent": true,
"layoutFlow": "column",
"bgColor": "var(--background)",
"textColor": "var(--text)",
"aiNotes": "Full screen flex-col container",
"children": [
{
"id": "header-strip",
"role": "container",
"name": "Top Command Strip",
"parentId": "root-container",
"w": 1920,
"h": 40,
"layoutFlow": "row",
"bgColor": "var(--surface2)",
"aiNotes": "Header for GlobalContextBar"
},
{
"id": "main-stage",
"role": "container",
"name": "Main Stage",
"parentId": "root-container",
"w": 1920,
"h": 1040,
"layoutFlow": "relative",
"bgColor": "var(--background)",
"aiNotes": "Main Content Area"
},
{
"id": "theme-engine",
"role": "container",
"name": "Theme Engine Overlay",
"parentId": "root-container",
"w": 320,
"h": 1080,
"layoutFlow": "relative",
"bgColor": "var(--surface2)",
"aiNotes": "Absolute positioned overlay for ThemeSidebar"
}
]
},
{
"id": "context-bar-inner",
"role": "table",
"name": "Global Context Bar",
"parentId": "header-strip",
"grid": {
"cols": [20, 60, 20],
"rows": [100]
},
"aiNotes": "Bar containing BackButton, InfoBadge, Flipper, ModelSelector, Settings, and AI input."
},
{
"id": "ws-flipper",
"role": "object",
"name": "Workspace Flipper",
"parentId": "context-bar-inner",
"_gridPos": { "ri": 0, "ci": 1 },
"contentType": "both",
"text": "Active Workspace",
"iconName": "layers",
"action": "open-flipper",
"tooltip": "Switch Workspace"
},
{
"id": "ai-command",
"role": "object",
"name": "AI Command Trigger",
"parentId": "context-bar-inner",
"_gridPos": { "ri": 0, "ci": 2 },
"contentType": "both",
"text": "AI",
"iconName": "sparkles",
"action": "toggle-ai",
"tooltip": "Command the engine"
}
]
}
}