{
  "name": "mono-repo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npx turbo run build",
    "dev": "pnpm --parallel --stream --filter=!@repo/voice-input run dev",
    "desktop": "npx turbo run desktop",
    "lint": "npx turbo run lint",
    "lint:fix": "npx turbo run lint:fix",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "db:push": "prisma db push --schema=apps/api/prisma/schema.prisma",
    "db:studio": "prisma studio --schema=apps/api/prisma/schema.prisma",
    "prepare": "echo husky"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "knip": "^5.73.3",
    "turbo": "^2.10.2",
    "typescript": "^5.4.5"
  },
  "packageManager": "pnpm@10.22.0",
  "dependencies": {
    "ignore": "^7.0.5",
    "zod": "^3.23.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "isolated-vm",
      "sharp"
    ],
    "overrides": {
      "sharp": "^0.34.5"
    }
  }
}
